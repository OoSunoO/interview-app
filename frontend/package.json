{
  "name": "interview-app",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run data && vite",
    "data": "node scripts/generate-data.js",
    "build": "npm run data && vite build",
    "preview": "vite preview",
    "serve": "npm run build && python3 -m http.server 8080 -d dist",
    "check": "svelte-check --tsconfig jsconfig.json",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run data && npm run format:check && npm run check && npm test"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "codemirror": "^6.0.2",
    "fuse.js": "^7.4.2",
    "highlight.js": "^11.11.0",
    "marked": "^18.0.4",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  }
}
